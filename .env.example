POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hotel_intelligence
# Local dev with Docker DB only: docker compose up db -d
# Use port 5433 if Windows already has PostgreSQL on 5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/hotel_intelligence
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
